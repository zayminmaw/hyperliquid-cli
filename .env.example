# Hard caps — off-limits to the LLM and the tuner (PLAN.md §9).
# Copy to .env and adjust. All vars are HL_-prefixed except ANTHROPIC_API_KEY.

# --- LLM credentials ---
# Shell environment wins over this file. `hl config show` displays it masked (first 4 + last 4).
# ANTHROPIC_API_KEY=sk-ant-...

# --- network + mainnet gate ---
HL_DEFAULT_NETWORK=paper
# One of three conditions to touch mainnet (also needs --network mainnet + typed confirm):
HL_ENABLE_MAINNET=0

# --- paths ---
# HL_DATA_DIR=~/.hyperliquid-cli
# HL_CONFIG_PATH=config/active_config.json

# --- risk ceilings (the order path can never exceed these) ---
HL_STARTING_EQUITY=10000
HL_MAX_NOTIONAL_PER_TRADE=1000
HL_MAX_CONCURRENT_POSITIONS=3
HL_DAILY_LOSS_LIMIT_PCT=5
# New-entry frequency cap per UTC day — an overtrading breaker independent of daily-loss (0 disables):
HL_MAX_TRADES_PER_DAY=0
HL_MAX_LEVERAGE=3
# Account-wide ceilings across the whole book (per-trade + concurrent-count caps don't bound
# the sum). Absolute dollar cap (0 disables — set one for real trading) and gross book
# notional ÷ equity (0 disables):
HL_MAX_TOTAL_EXPOSURE_USD=0
HL_MAX_GROSS_LEVERAGE=5
HL_RR_FLOOR=1.5
# Distance-to-liquidation floor, percent (wave-2 M). A live position whose mark is within
# this % of its exchange liquidationPx raises a critical `liquidation_near` alert (its stop
# is missing or below liquidation). Live only — paper reports no liquidationPx. 0 disables.
HL_MIN_LIQUIDATION_DISTANCE_PCT=5.0
# Pre-fire maintenance-margin ceiling as a fraction of equity (wave-2 M). The gate refuses a
# new entry once crossMaintenanceMarginUsed / equity exceeds this (the book is too close to
# liquidation to add risk). Live only (paper reports 0); 0 disables.
HL_MAX_MAINTENANCE_MARGIN_FRAC=0.5
HL_MAX_SIGNAL_AGE_MINUTES=30
# Exchange-enforced order floor (Hyperliquid: $10) — the gate rejects below this early:
HL_MIN_ORDER_NOTIONAL=10
# Worst acceptable entry fill vs mid, percent (audit X-1). Every non-reduce-only market
# order — the executor's entries AND `hl trade order market` — becomes an IOC limit at
# mid ± this; a non-fill is a clean no-op. Reduce-only closes stay wide — a flatten must fill.
HL_MAX_ENTRY_SLIPPAGE_PCT=0.3
# Taker fee rate in percent (Hyperliquid entry tier ~0.045% taker; check your live tier).
# Realized P&L and R are booked NET of the round-trip taker fee so graduation and the tuner
# stay cost-honest (wave-2 K); paper models this fee for paper->testnet->mainnet parity.
# 0 disables (paper only — live always pays the real fee).
HL_TAKER_FEE_PCT=0.045
# Net the round-trip taker fee into the R:R-at-mark the gate checks (#2a): the honest bar
# is (|tp-mark| - 2*fee*mark)/(|mark-sl| + 2*fee*mark) >= RR_FLOOR. Only ever tightens
# (rejects setups that don't clear fees), hardest on tight-stop scalps. 0/false disables.
HL_FEE_ADJUSTED_RR=1
# Max WAIT re-checks before a deferred candidate is dropped (0 disables deferral):
HL_FOLLOWUP_MAX_ATTEMPTS=3
HL_ALLOWED_COINS=BTC,ETH,SOL

# --- sentry churn caps (PLAN.md §14 — code-enforced; "day" = rolling 24h) ---
# A position is LLM-evaluated at most this often (bounds spend + log volume):
HL_SENTRY_EVAL_INTERVAL_MINUTES=15
# Per-position cooldown after any applied management action:
HL_SENTRY_MIN_ACTION_INTERVAL_MINUTES=30
HL_SENTRY_MAX_ACTIONS_PER_POSITION_PER_DAY=4
HL_SENTRY_MAX_LLM_CALLS_PER_DAY=200
# No extend_tp within this window of a reduce/scale-out (and vice versa):
HL_SENTRY_OPPOSING_WINDOW_MINUTES=120
# ADD (pyramiding) — winners only, stop raised with every add, sized by code.
# 0 = disabled (the default): ADD is the one risk-INCREASING action, kept off until
# the book graduates; raising this is a deliberate risk decision (2026-07 audit, L-3).
HL_SENTRY_ADD_MIN_R=1.0
HL_SENTRY_MAX_ADDS_PER_POSITION=0

# --- graduation thresholds (mainnet-readiness gate, checked in `exec report`) ---
HL_GRADUATION_MIN_TRADES=20
HL_GRADUATION_MIN_DAYS=7
HL_GRADUATION_MIN_EXPECTANCY=0.0

# --- conviction-calibration acceptance (precondition to re-enable conviction→size scaling) ---
# `exec report`'s calibration_verdict.ready must be true before flipping sizing.enabled on:
# higher-conviction buckets must realize higher avg_R across the range, on real sample.
HL_CALIBRATION_MIN_BUCKET_N=10
HL_CALIBRATION_MIN_SPREAD_R=0.2

# --- keystore encryption (2026-07 audit, O-1) ---
# Set to encrypt agent keys at rest (eth_account V3 keystore JSON). New keys saved by
# `hl account add` are encrypted; existing plaintext keys keep loading. Shell env wins;
# keep the passphrase out of backups that include ~/.hyperliquid-cli/keys.
# HL_KEYSTORE_PASSPHRASE=

# --- reconciliation response (2026-07 audit, O-2) ---
# What an executor pass does about an exchange position the ledger doesn't know:
# alert (default) pages a human; adopt additionally books STOP-PROTECTED positions via
# the sentry adopt path (stopless ones still only alert; flattening stays manual).
HL_RECONCILE_ACTION=alert

# --- decision source (2026-07 audit, L-2) ---
# Which arbiter judges candidates: "llm" (the decision model), "rule" (deterministic
# act-on-every-gate-valid-setup baseline), or "follow_source" (obey the producer's own
# verdict — act when source_direction matches the setup's side, else skip). The baselines
# take no LLM call and no key. A/B: run each in shadow under separate HL_DATA_DIRs, then
# diff with `exec report --compare <other_data_dir>`.
HL_DECISION_SOURCE=llm

# --- models + token budgets ---
HL_DECISION_MODEL=claude-sonnet-5
HL_DECISION_MAX_TOKENS=1024
HL_TUNER_MODEL=claude-sonnet-5
HL_TUNER_MAX_TOKENS=4096

# --- agent mode (PLAN.md §15) ---
# Producers drop candidate-batch JSON files under this dir (per-network subdir
# appended; relative paths anchor to HL_DATA_DIR). Default: <data_dir>/intake
#HL_AGENT_INTAKE_DIR=intake
# When the daily jobs run (report; journal from 7b), HH:MM UTC:
HL_AGENT_DAILY_UTC=00:10
# Journal narrative (one out-of-path opus call per day; `hl journal write`):
HL_JOURNAL_MODEL=claude-opus-4-8
HL_JOURNAL_MAX_TOKENS=2048
# Reflection memory bounds (§15.4) — lessons injected into decision context:
HL_AGENT_REFLECT_INJECT_MAX=3
HL_AGENT_REFLECT_MAX_CHARS=240
# Liveness (audit F): age (s) past which `agent status`/`agent watchdog` call the supervisor
# dead (0 = derive as 3× the intake poll). A cron `hl agent watchdog` pages a dead loop:
HL_AGENT_STALE_AFTER_SECONDS=0
