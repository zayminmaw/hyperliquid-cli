# Hard caps — off-limits to the LLM and the tuner (PLAN.md §9).
# Copy to .env and adjust. All vars are HL_-prefixed.

# --- network + mainnet gate ---
HL_DEFAULT_NETWORK=paper
# One of three conditions to touch mainnet (also needs --network mainnet + typed confirm):
HL_ENABLE_MAINNET=0

# --- paths ---
# HL_DATA_DIR=~/.hyperliquid-cli
# HL_CONFIG_PATH=config/active_config.json

# --- risk ceilings (the order path can never exceed these) ---
HL_STARTING_EQUITY=10000
HL_MAX_NOTIONAL_PER_TRADE=1000
HL_MAX_CONCURRENT_POSITIONS=3
HL_DAILY_LOSS_LIMIT_PCT=5
HL_MAX_LEVERAGE=3
HL_RR_FLOOR=1.5
HL_MAX_SIGNAL_AGE_MINUTES=30
HL_ALLOWED_COINS=BTC,ETH,SOL

# --- models + token budgets ---
HL_DECISION_MODEL=claude-sonnet-4-6
HL_DECISION_MAX_TOKENS=1024
HL_TUNER_MODEL=claude-opus-4-8
HL_TUNER_MAX_TOKENS=4096
